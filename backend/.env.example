# ===========================================
# LLM（对话生成）— DeepSeek 或 OpenAI 兼容 API
# ===========================================
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# 也可用 OPENAI_API_KEY / OPENAI_BASE_URL 作为回退
LLM_MODEL=deepseek-chat

# ===========================================
# Embedding（文档向量化与检索）
# ===========================================
EMBEDDING_API_KEY=sk-your-embedding-key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
# 示例（SiliconFlow）：EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1

# ===========================================
# 服务与安全
# ===========================================
PORT=8000
DEBUG=true
SECRET_KEY=change-me-use-long-random-string-min-32-chars
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# ===========================================
# 数据目录（路径均相对 backend/）
# ===========================================
# 默认 SQLite、上传与索引落在 backend/data/
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
# Windows 下 FAISS 建议纯英文路径；Linux/macOS 可用 ./data/indexes
INDEX_DIR=./data/indexes

# ===========================================
# Redis / Celery（可选；索引异步任务需要）
# ===========================================
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
CACHE_REDIS_URL=redis://127.0.0.1:6379/0
RETRIEVAL_CACHE_TTL_SECONDS=600

# ===========================================
# 检索拒答（FAISS L2，越小越相似；0=仅空结果拒答）
# ===========================================
RETRIEVAL_MAX_DISTANCE=0

# ===========================================
# 索引任务超时（秒）
# ===========================================
INDEX_JOB_STALE_QUEUED_SECONDS=30
INDEX_JOB_STALE_RUNNING_SECONDS=30

# ===========================================
# MinIO / S3（可选；未配置时使用本地文件存储）
# ===========================================
# S3_ENDPOINT_INTERNAL=http://127.0.0.1:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin123
# S3_BUCKET=kb-files
